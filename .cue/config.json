  "worktree": {
    "enabled": true,
    "onComplete": "push-and-pr",
    "autoMergePr": true
  },
  "proofGate": {
    "enabled": true,
    "requireE2E": true,
    "requireVisual": true,
    "deferWhenPlaywrightMissing": true
  },
  "review": {
    "enabled": true,
    "path": "auto",
    "scope": [
      "prompt",
      "tool"
    ],
    "budgetMs": 5000,
    "defaultModel": "sonnet",
    "advisorModel": "sonnet",
    "policyModel": "sonnet",
    "parallelTimeoutMs": 5000,
    "dialogicTimeoutMs": 120000,
    "mergeVerifyTimeoutMs": 120000,
    "autoReviewOnSpecCreate": true,
