  },
  "memorySaveGuard": {
    "enabled": true,
    "signalEnabled": true
  },
  "deepModuleGuard": {
    "enabled": true,
    "detectionMode": "hybrid",
    "severityFloor": "BLOCK",
    "minLinesChanged": 15,
    "minNewExports": 1,
    "exemptPaths": [
      "tests/**",
      "docs/**",
      "plans/**"
    ],
    "lightweightFileThreshold": 2,
    "lightweightLocThreshold": 100,
    "strictInterfaceMatch": true,
    "crossModuleInternalImports": true,
    "importCycles": true,
    "filesTouchedMatchesDiff": true
