  "memory": {
    "autoPrToMain": true,
    "autoPrBase": "working",
    "autoCommit": true
  },
  "artifacts": {
    "autoCommit": true
  },
  "neuralMemory": {
    "enabled": true,
    "signalEnabled": true,
    "spreadingActivation": true,
    "decayEnabled": true,
    "typedEdges": true,
    "maxHops": 2,
    "tripletScoring": true,
    "queryDecomposition": true,
    "multiCollectionSearch": true,
