{
  "fileMap": {
    "codeExtensions": []
  },
  "sandbox": {
    "enabled": true,
    "autoAllow": true,
    "additionalAllowWrite": [],
    "additionalAllowedDomains": [],
    "excludedCommands": [
      "docker"
    ],
    "strictMode": false
  },
  "autoCommit": true,
  "autoAdvance": false,
  "autoPush": true,
  "maxRetries": 3,
  "maxTransientRetries": 5,
  "ralphMaxIterations": 25,
  "maxParallelAgents": 3,
  "port": 18300,
  "gitDryRun": false,
  "rebaseBeforeCommit": false,
  "debugLog": false,
  "memoryTrace": false,
